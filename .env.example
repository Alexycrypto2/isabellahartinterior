# .env.example

# GitHub Integration
VITE_GITHUB_TOKEN=your_github_token_here
VITE_GITHUB_REPO=your_github_repo_here

# Claude AI Integration
VITE_CLAUDE_API_KEY=your_claude_api_key_here

# Amazon Associates
